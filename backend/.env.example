# ──────────────────────────────────────────────────────────────────────────────
# HealthTech PHI/PII Redaction Pipeline — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/redaction.db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI (Day 3+) ───────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Microsoft Presidio (Day 2+) ───────────────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://localhost:5002
PRESIDIO_ANONYMIZER_URL=http://localhost:5003
